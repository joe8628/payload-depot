#!/usr/bin/env bash
set -euo pipefail

RIG_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
RIG_VERSION="1.0.0"

# ── Helpers ───────────────────────────────────────────────────────────────────

log()  { echo "[rig-stage] $*"; }
err()  { echo "[rig-stage] ERROR: $*" >&2; }
skip() { echo "[rig-stage] ~ Skipped              → $*"; }
ok()   { echo "[rig-stage] ✓ $*"; }

usage() {
  cat <<EOF
Usage: rig-stage <command> [options]

Commands:
  install        Bootstrap the current directory as an AI-assisted project
  update         Refresh agents and skills without touching user config files
  upgrade        Pull latest Rig source from GitHub then run update
  list           List available agents and skills
  list-targets   List available install targets
  version        Print Rig version
  help           Print this message

Options for install:
  --target <name>       Target adapter to use (default: claude-code)
  --force               Overwrite existing config files
  --dry-run             Print install plan without writing files
  --no-hooks            Skip git hook installation
  --no-codebase-index   Skip codebase context index initialisation

Options for update:
  --target <name>       Target adapter to use (default: claude-code)
EOF
}

# ── F-001: CLAUDE.md placeholder substitution ────────────────────────────────

_detect_project_name() {
  local name=""
  if [[ -f "pyproject.toml" ]]; then
    name=$(grep -m1 '^name[[:space:]]*=' pyproject.toml \
           | sed 's/[^=]*=[[:space:]]*"\(.*\)"/\1/' 2>/dev/null || true)
  fi
  if [[ -z "$name" ]] && [[ -f "package.json" ]]; then
    name=$(grep -m1 '"name"' package.json \
           | sed 's/.*"name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/' 2>/dev/null || true)
  fi
  if [[ -z "$name" ]]; then
    name=$(basename "$(pwd)")
  fi
  echo "$name"
}

_detect_lang_tools() {
  if [[ -f "pyproject.toml" ]]; then
    echo "Python + ruff/mypy"
  elif [[ -f "package.json" ]]; then
    echo "TypeScript/JS + eslint/tsc"
  elif [[ -f "CMakeLists.txt" ]] || [[ -f "Makefile" ]]; then
    echo "C/C++ + clang-tidy"
  fi
  # else: empty — placeholder left unchanged so user knows to fill it in
}

_detect_description() {
  if [[ -f "README.md" ]]; then
    awk '/^#[[:space:]]/{found=1; next} found && /[^[:space:]]/{print; exit}' README.md
  fi
}

substitute_placeholders() {
  local dest="$1"
  local name lang desc
  name=$(_detect_project_name)
  lang=$(_detect_lang_tools)
  desc=$(_detect_description)
  if [[ -n "$name" ]]; then sed -i "s|<Project Name>|$name|g" "$dest"; fi
  if [[ -n "$lang" ]]; then sed -i "s|<language and primary tools>|$lang|g" "$dest"; fi
  if [[ -n "$desc" ]]; then sed -i "s|<what this project does>|$desc|g" "$dest"; fi
}

_log_substitutions() {
  local name lang desc
  name=$(_detect_project_name)
  lang=$(_detect_lang_tools)
  desc=$(_detect_description)
  log "[dry-run] CLAUDE.md placeholder substitutions:"
  log "[dry-run]   <Project Name>             → ${name:-(unchanged)}"
  log "[dry-run]   <language and primary tools> → ${lang:-(unchanged)}"
  log "[dry-run]   <what this project does>   → ${desc:-(unchanged)}"
}

# ── F-001: .gitignore maintenance ────────────────────────────────────────────

_ensure_gitignore_entries() {
  local updated=false
  if ! grep -qF "Rig session files" .gitignore 2>/dev/null; then
    cat >> .gitignore <<'GITIGNORE'

# Rig session files — ephemeral, not committed
SCRATCHPAD.md
.rig-verified

# Codebase context — local vector DB, not committed
.codebase-context/chroma/
GITIGNORE
    updated=true
  else
    # Block already present — ensure individual entries exist (upgrade path)
    if ! grep -qF ".rig-verified" .gitignore 2>/dev/null; then
      printf '\n.rig-verified\n' >> .gitignore
      updated=true
    fi
    if ! grep -qF ".codebase-context/chroma/" .gitignore 2>/dev/null; then
      printf '\n.codebase-context/chroma/\n' >> .gitignore
      updated=true
    fi
  fi
  if $updated; then
    ok ".gitignore           → updated"
  fi
}

# ── Commands ──────────────────────────────────────────────────────────────────

cmd_version() { echo "rig-stage $RIG_VERSION"; }

cmd_help() { usage; }

cmd_upgrade() {
  if [[ ! -d "$RIG_DIR/.git" ]]; then
    err "No .git directory found in $RIG_DIR — cannot upgrade."
    exit 1
  fi

  local before
  before=$(git -C "$RIG_DIR" rev-parse HEAD)

  log "Pulling latest from GitHub..."
  git -C "$RIG_DIR" fetch origin main
  git -C "$RIG_DIR" reset --hard origin/main

  local after
  after=$(git -C "$RIG_DIR" rev-parse HEAD)

  if [[ "$before" == "$after" ]]; then
    log "Already up to date."
  else
    ok "Upgraded $(git -C "$RIG_DIR" rev-parse --short "$before") → $(git -C "$RIG_DIR" rev-parse --short "$after")"
    git -C "$RIG_DIR" log --oneline "${before}..${after}"
  fi

  if [[ -d ".git" ]]; then
    log "Updating project install..."
    # Run the freshly-pulled script as a subprocess so we use the latest
    # cmd_update — not the old version loaded into this bash process's memory.
    # update never touches user config files, so no --force is needed.
    bash "$RIG_DIR/rig-stage" update
  else
    skip "Project update (not inside a project directory)"
  fi
}

cmd_update() {
  local target="claude-code"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --target) target="$2"; shift 2 ;;
      *) err "Unknown flag: $1"; exit 1 ;;
    esac
  done

  if [[ ! -d ".git" ]]; then
    err "No .git directory found in current path."
    err "Initialise a git repository first: git init"
    exit 2
  fi

  local adapter_dir="$RIG_DIR/targets/$target"
  if [[ ! -f "$adapter_dir/adapter.sh" ]]; then
    err "adapter.sh not found in $adapter_dir — run: rig-stage list-targets"
    exit 1
  fi

  # shellcheck source=/dev/null
  source "$adapter_dir/adapter.sh"

  log "Updating agents and skills only (config files preserved)..."

  adapter_pre_install
  mkdir -p "$AGENT_INSTALL_PATH"
  mkdir -p "$SKILL_INSTALL_PATH"

  local agent_count=0
  if compgen -G "$RIG_DIR/agents/*.md" > /dev/null 2>&1; then
    agent_count=$(find "$RIG_DIR/agents" -name "*.md" | wc -l | tr -d ' ')
    cp "$RIG_DIR/agents/"*.md "$AGENT_INSTALL_PATH/"
  fi
  ok "Agents updated  → $AGENT_INSTALL_PATH ($agent_count files)"

  local skill_count=0
  if compgen -G "$RIG_DIR/skills/*.md" > /dev/null 2>&1; then
    skill_count=$(find "$RIG_DIR/skills" -name "*.md" ! -name "registry.md" | wc -l | tr -d ' ')
    cp "$RIG_DIR/skills/"*.md "$SKILL_INSTALL_PATH/"
  fi
  ok "Skills updated  → $SKILL_INSTALL_PATH ($skill_count files)"

  for pair in "${CONFIG_FILES[@]}"; do
    local dest="${pair##*:}"
    skip "$dest (user config — use install --force to overwrite)"
  done

  _ensure_gitignore_entries

  adapter_post_install
  # adapter_post_install already clears .rig-verified; make explicit here too
  rm -f ".rig-verified"

  log "Done. $agent_count agents, $skill_count skills updated."
}

cmd_list() {
  echo "Agents:"
  for f in "$RIG_DIR/agents/"*.md; do
    [[ -f "$f" ]] && echo "  $(basename "$f" .md)"
  done
  echo ""
  echo "Skills:"
  for f in "$RIG_DIR/skills/"*.md; do
    [[ -f "$f" ]] || continue
    local base
    base="$(basename "$f" .md)"
    [[ "$base" == "registry" ]] && continue
    echo "  $base"
  done
}

cmd_list_targets() {
  echo "Available targets:"
  for adapter in "$RIG_DIR/targets/"*/adapter.sh; do
    [[ -f "$adapter" ]] || continue
    local target_dir
    target_dir="$(dirname "$adapter")"
    local name
    name="$(basename "$target_dir")"
    local desc=""
    local readme="$target_dir/README.md"
    if [[ -f "$readme" ]]; then
      desc=$(awk '/^#[[:space:]]/{found=1; next} found && /[^[:space:]]/{print; exit}' "$readme")
    fi
    printf "  %-16s %s\n" "$name" "${desc:-(no description)}"
  done
}

cmd_install() {
  local target="claude-code" force=false dry_run=false no_hooks=false no_index=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --target)             target="$2"; shift 2 ;;
      --force)              force=true; shift ;;
      --dry-run)            dry_run=true; shift ;;
      --no-hooks)           no_hooks=true; shift ;;
      --no-codebase-index)  no_index=true; shift ;;
      *) err "Unknown flag: $1"; exit 1 ;;
    esac
  done

  # Pre-flight checks
  if [[ ! -d ".git" ]]; then
    err "No .git directory found in current path."
    err "Initialise a git repository first: git init"
    exit 2
  fi

  local adapter_dir="$RIG_DIR/targets/$target"
  if [[ ! -d "$adapter_dir" ]]; then
    err "Target '$target' not found. Available targets: $(ls "$RIG_DIR/targets/" | tr '\n' ' ')"
    err "Run \`rig-stage help\` for details."
    exit 3
  fi

  if [[ ! -f "$adapter_dir/adapter.sh" ]]; then
    err "adapter.sh not found in $adapter_dir"
    exit 1
  fi

  # Load target adapter
  # shellcheck source=/dev/null
  source "$adapter_dir/adapter.sh"

  log "Installing for target: $target"

  # Dry-run wrapper
  maybe() {
    if $dry_run; then
      echo "[rig-stage] [dry-run] $*"
    else
      "$@"
    fi
  }

  # Step 1: adapter pre-install
  $dry_run || adapter_pre_install

  # Steps 2-3: Create install directories
  maybe mkdir -p "$AGENT_INSTALL_PATH"
  maybe mkdir -p "$SKILL_INSTALL_PATH"

  # Step 4: Copy agents (always overwrite — versioned content)
  local agent_count=0
  if compgen -G "$RIG_DIR/agents/*.md" > /dev/null 2>&1; then
    agent_count=$(find "$RIG_DIR/agents" -name "*.md" | wc -l | tr -d ' ')
  fi
  if $dry_run; then
    log "[dry-run] Copy agents/ → $AGENT_INSTALL_PATH ($agent_count files)"
  else
    if [[ $agent_count -gt 0 ]]; then
      cp "$RIG_DIR/agents/"*.md "$AGENT_INSTALL_PATH/"
    fi
    ok "Agents copied       → $AGENT_INSTALL_PATH ($agent_count files)"
  fi

  # Step 5: Copy skills (always overwrite)
  local skill_count=0
  if compgen -G "$RIG_DIR/skills/*.md" > /dev/null 2>&1; then
    skill_count=$(find "$RIG_DIR/skills" -name "*.md" ! -name "registry.md" | wc -l | tr -d ' ')
  fi
  if $dry_run; then
    log "[dry-run] Copy skills/ → $SKILL_INSTALL_PATH ($skill_count files)"
  else
    if [[ $skill_count -gt 0 ]]; then
      cp "$RIG_DIR/skills/"*.md "$SKILL_INSTALL_PATH/"
    fi
    ok "Skills copied        → $SKILL_INSTALL_PATH ($skill_count files)"
  fi

  # Step 6: Write config templates (skip if exists, unless --force)
  for pair in "${CONFIG_FILES[@]}"; do
    local template="${pair%%:*}"
    local dest="${pair##*:}"
    local src="$adapter_dir/$template"
    local dest_dir
    dest_dir="$(dirname "$dest")"

    if $dry_run; then
      log "[dry-run] Write config → $dest"
      if [[ "$(basename "$dest")" == "CLAUDE.md" ]]; then _log_substitutions; fi
      continue
    fi

    if [[ "$dest_dir" != "." ]]; then mkdir -p "$dest_dir"; fi

    if [[ -f "$dest" ]] && ! $force; then
      skip "$dest (already exists, use --force to overwrite)"
    else
      cp "$src" "$dest"
      if [[ "$(basename "$dest")" == "CLAUDE.md" ]]; then substitute_placeholders "$dest"; fi
      ok "Config written       → $dest (new)"
    fi
  done

  # Step 7: Copy session templates
  # SCRATCHPAD.md is ephemeral — always overwrite.
  # HANDOFF.md and DECISIONS.md accumulate session history — skip if they exist.
  if $dry_run; then
    log "[dry-run] Copy session/SCRATCHPAD.md.template → ./SCRATCHPAD.md (always)"
    log "[dry-run] Copy session/HANDOFF.md.template    → ./HANDOFF.md (skip if exists)"
    log "[dry-run] Copy session/DECISIONS.md.template  → ./DECISIONS.md (skip if exists)"
  else
    cp "$RIG_DIR/session/SCRATCHPAD.md.template" "./SCRATCHPAD.md"
    ok "Session template     → ./SCRATCHPAD.md (overwritten)"
    for persistent in HANDOFF.md DECISIONS.md; do
      if [[ -f "./$persistent" ]]; then
        skip "./$persistent (already exists — session history preserved)"
      else
        cp "$RIG_DIR/session/$persistent.template" "./$persistent"
        ok "Session template     → ./$persistent (new)"
      fi
    done
  fi

  # Step 8: Append .gitignore entries
  if $dry_run; then
    log "[dry-run] Append .gitignore entries"
  else
    _ensure_gitignore_entries
  fi

  # Step 9: Install pre-commit hook
  if $no_hooks; then
    skip ".git/hooks/pre-commit (--no-hooks)"
  elif $dry_run; then
    log "[dry-run] Install .git/hooks/pre-commit"
  else
    cp "$RIG_DIR/hooks/pre-commit" ".git/hooks/pre-commit"
    chmod +x ".git/hooks/pre-commit"
    ok "Git hook installed   → .git/hooks/pre-commit"
  fi

  # Step 10: Run codebase-context install + ccindex init
  if $no_index; then
    skip "codebase index (--no-codebase-index)"
  elif $dry_run; then
    log "[dry-run] Run ccindex init"
  else
    local cb_install="$RIG_DIR/codebase-context/install.sh"
    if [[ -x "$cb_install" ]]; then
      "$cb_install" || { err "codebase-context install failed"; exit 4; }
    fi
    if command -v ccindex &>/dev/null; then
      # Pipe answers to ccindex's two interactive prompts:
      #   1. "Add repo map reference to CLAUDE.md?" → y
      #   2. "Install git post-commit hook?"        → n (Rig manages its own hook)
      printf "y\nn\n" | ccindex init || { err "ccindex init failed (exit $?)"; exit 4; }
      ok "Codebase index       → initialised (.codebase-context/)"
    else
      log "WARNING: ccindex not found on PATH — skipping index init"
      log "         Run: cd codebase-context && ./install.sh"
    fi
  fi

  # Step 11: adapter post-install
  $dry_run || adapter_post_install

  log "Done. $agent_count agents, $skill_count skills, ${#CONFIG_FILES[@]} config files, 3 session templates."
}

# ── Dispatch ──────────────────────────────────────────────────────────────────

COMMAND="${1:-help}"
shift || true

case "$COMMAND" in
  install)      cmd_install "$@" ;;
  update)       cmd_update "$@" ;;
  upgrade)      cmd_upgrade ;;
  list)         cmd_list ;;
  list-targets) cmd_list_targets ;;
  version)      cmd_version ;;
  help|--help|-h) cmd_help ;;
  *) err "Unknown command: $COMMAND"; exit 1 ;;
esac
