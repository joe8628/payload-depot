{
  "mcpServers": {
    "codebase-context": {
      "command": "ccindex",
      "args": ["serve"],
      "type": "stdio"
    }
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Bash"
    ],
    "deny": [
      "Network"
    ]
  },
  "tools": {
    "bash": {
      "allowedCommands": [
        "git",
        "python",
        "python3",
        "node",
        "npm",
        "npx",
        "tsc",
        "mypy",
        "ruff",
        "eslint",
        "clang",
        "clang++",
        "make",
        "cmake",
        "pip",
        "pip3",
        "pip-audit",
        "npm audit",
        "ccindex"
      ]
    }
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/context-monitor.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-end.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-write-secret-scan.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-write-secret-scan.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-lint.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-lint.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-bash-test.sh"
          }
        ]
      }
    ]
  }
}
